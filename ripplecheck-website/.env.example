GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
DB_HOST=localhost
DB_NAME=ripplecheck
DB_USER=your_db_user
DB_PASSWORD=your_db_password
# HMAC key signing the token handed to the Electron app after in-app
# GitHub login (see app_token.php). Generate with: openssl rand -base64 32
APP_TOKEN_SECRET=your_random_secret
# Symmetric key encrypting the real GitHub access token at rest (see
# github_token.php) — a different secret from APP_TOKEN_SECRET above since
# encryption and HMAC signing are different primitives. Generate with:
# php -r "echo base64_encode(random_bytes(SODIUM_CRYPTO_SECRETBOX_KEYBYTES));"
GITHUB_TOKEN_ENCRYPTION_KEY=your_base64_encoded_32_byte_key

# Note: AI-powered scan enrichment is now Bring-Your-Own-Key and fully local —
# the Electron app calls Anthropic directly with a key the user pastes into
# Settings (stored encrypted on their machine). The server no longer proxies
# any Anthropic calls, so no ANTHROPIC_API_KEY is needed here.
